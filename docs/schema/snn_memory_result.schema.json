{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://remanentia.com/schemas/snn_memory_result.v1.schema.json",
  "title": "Remanentia Temporal SNN Memory Result",
  "description": "Exact public output contract for either a cue-only probe or a matched-control benchmark report.",
  "oneOf": [
    {"$ref": "#/$defs/probe"},
    {"$ref": "#/$defs/benchmark"}
  ],
  "$defs": {
    "probe": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "label", "scores", "completion_spikes", "recurrence_input_ratio", "weight_digest_unchanged"],
      "properties": {
        "schema_version": {"const": 1},
        "label": {
          "type": ["string", "null"],
          "minLength": 1
        },
        "scores": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "number", "minimum": -1.0, "maximum": 1.0}
        },
        "completion_spikes": {"type": "integer", "minimum": 0},
        "recurrence_input_ratio": {"type": "number", "minimum": 0.0},
        "weight_digest_unchanged": {"const": true}
      },
      "x-remanentia-integrity": {
        "input_boundary": "cue-only",
        "candidate_documents": false,
        "plasticity_enabled": false
      }
    },
    "benchmark": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "seeds", "conditions", "p_at_1", "trained_minus_shuffled", "gates", "limits"],
      "properties": {
        "schema_version": {"const": 1},
        "seeds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/seed"}
        },
        "conditions": {
          "type": "object",
          "additionalProperties": false,
          "required": ["trained", "shuffled", "random", "zero", "encoder-only"],
          "properties": {
            "trained": {"$ref": "#/$defs/seedDetails"},
            "shuffled": {"$ref": "#/$defs/seedDetails"},
            "random": {"$ref": "#/$defs/seedDetails"},
            "zero": {"$ref": "#/$defs/seedDetails"},
            "encoder-only": {"$ref": "#/$defs/seedDetails"}
          }
        },
        "p_at_1": {
          "type": "object",
          "additionalProperties": false,
          "required": ["trained", "shuffled", "random", "zero", "encoder-only"],
          "properties": {
            "trained": {"$ref": "#/$defs/probability"},
            "shuffled": {"$ref": "#/$defs/probability"},
            "random": {"$ref": "#/$defs/probability"},
            "zero": {"$ref": "#/$defs/probability"},
            "encoder-only": {"$ref": "#/$defs/probability"}
          }
        },
        "trained_minus_shuffled": {
          "type": "object",
          "additionalProperties": false,
          "required": ["mean", "lower", "upper", "pairs"],
          "properties": {
            "mean": {"type": "number", "minimum": -1.0, "maximum": 1.0},
            "lower": {"type": "number", "minimum": -1.0, "maximum": 1.0},
            "upper": {"type": "number", "minimum": -1.0, "maximum": 1.0},
            "pairs": {"type": "integer", "minimum": 1}
          }
        },
        "gates": {
          "type": "object",
          "description": "Schema v1 pins every reported G1/G2 gate (g1_pass, g2_effect_threshold_pass, g2_pass) to false: the current benchmark self-calibrates each stored signature from the cue it then scores, so no v1 producer may emit a passed gate. This object does not decide G0/G3/G4. A held-out harness able to legitimately pass a gate must publish under schema_version 2 with boolean gates.",
          "additionalProperties": false,
          "required": ["g1_pass", "g2_effect_threshold_pass", "g2_pass"],
          "properties": {
            "g1_pass": {"const": false},
            "g2_effect_threshold_pass": {"const": false},
            "g2_pass": {"const": false}
          }
        },
        "limits": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "seed": {"type": "integer", "minimum": 0, "maximum": 4294967295},
    "probability": {"type": "number", "minimum": 0.0, "maximum": 1.0},
    "seedDetails": {
      "type": "object",
      "minProperties": 1,
      "patternProperties": {
        "^(0|[1-9][0-9]*)$": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/detail"}
        }
      },
      "additionalProperties": false
    },
    "detail": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "prediction", "correct", "completion_spikes"],
      "properties": {
        "label": {"type": "string", "minLength": 1},
        "prediction": {
          "type": ["string", "null"],
          "minLength": 1
        },
        "correct": {"type": "boolean"},
        "completion_spikes": {"type": "integer", "minimum": 0}
      }
    }
  }
}
