{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://remanentia.com/schemas/snn_memory_candidate_bank_v2.schema.json",
  "title": "Remanentia temporal SNN candidate-signature bank v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_type",
    "state",
    "lane_role",
    "checkpoint",
    "identities",
    "signature_layout",
    "signatures",
    "calibration",
    "scoring",
    "build",
    "self_sha256"
  ],
  "properties": {
    "schema_version": {
      "const": 2
    },
    "artifact_type": {
      "const": "snn-memory-candidate-bank-v2"
    },
    "state": {
      "enum": [
        "fixture_only",
        "pre_result"
      ]
    },
    "lane_role": {
      "const": "lane_p"
    },
    "checkpoint": {
      "$ref": "#/$defs/checkpointBinding"
    },
    "identities": {
      "$ref": "#/$defs/identities"
    },
    "signature_layout": {
      "$ref": "#/$defs/signatureLayout"
    },
    "signatures": {
      "$ref": "#/$defs/signatures"
    },
    "calibration": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "record_id",
          "source_cue_sha256",
          "current_semantic_digest",
          "dtype",
          "shape",
          "input_current",
          "encoder_identity",
          "encoder_directory_digest",
          "encoder_config_digest",
          "model_config_digest",
          "pre_state_digest",
          "post_state_digest",
          "input_weights_digest",
          "final_weights_digest",
          "topology_digest",
          "cue_digest",
          "backend_build_digest",
          "raster_digest"
        ],
        "properties": {
          "record_id": {
            "$ref": "#/$defs/recordId"
          },
          "source_cue_sha256": {
            "$ref": "#/$defs/sha256"
          },
          "current_semantic_digest": {
            "$ref": "#/$defs/sha256"
          },
          "dtype": {
            "const": "<f8"
          },
          "shape": {
            "type": "array",
            "minItems": 2,
            "maxItems": 2,
            "items": {
              "type": "integer",
              "minimum": 1
            }
          },
          "input_current": {
            "type": "number",
            "exclusiveMinimum": 0.0
          },
          "encoder_identity": {
            "type": "string",
            "minLength": 1
          },
          "encoder_directory_digest": {
            "$ref": "#/$defs/sha256"
          },
          "encoder_config_digest": {
            "$ref": "#/$defs/sha256"
          },
          "model_config_digest": {
            "$ref": "#/$defs/sha256"
          },
          "pre_state_digest": {
            "$ref": "#/$defs/sha256"
          },
          "post_state_digest": {
            "$ref": "#/$defs/sha256"
          },
          "input_weights_digest": {
            "$ref": "#/$defs/sha256"
          },
          "final_weights_digest": {
            "$ref": "#/$defs/sha256"
          },
          "topology_digest": {
            "$ref": "#/$defs/sha256"
          },
          "cue_digest": {
            "$ref": "#/$defs/sha256"
          },
          "backend_build_digest": {
            "$ref": "#/$defs/sha256"
          },
          "raster_digest": {
            "$ref": "#/$defs/sha256"
          }
        }
      }
    },
    "scoring": {
      "$ref": "#/$defs/scoring"
    },
    "build": {
      "$ref": "#/$defs/build"
    },
    "self_sha256": {
      "$ref": "#/$defs/sha256"
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "gitSha1": {
      "type": "string",
      "pattern": "^[a-f0-9]{40}$"
    },
    "recordId": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "checkpointBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "descriptor_self_sha256",
        "manifest_file_sha256",
        "manifest_payload_self_sha256"
      ],
      "properties": {
        "descriptor_self_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "manifest_file_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "manifest_payload_self_sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "identities": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "experiment_digest",
        "dataset_digest",
        "task_set_digest",
        "candidate_set_digest",
        "d1_file_sha256",
        "d2_file_sha256",
        "lane_role",
        "seed",
        "condition",
        "ordered_record_ids"
      ],
      "properties": {
        "experiment_digest": {
          "$ref": "#/$defs/sha256"
        },
        "dataset_digest": {
          "$ref": "#/$defs/sha256"
        },
        "task_set_digest": {
          "$ref": "#/$defs/sha256"
        },
        "candidate_set_digest": {
          "$ref": "#/$defs/sha256"
        },
        "d1_file_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "d2_file_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "lane_role": {
          "const": "lane_p"
        },
        "seed": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4294967295
        },
        "condition": {
          "enum": [
            "trained",
            "shuffled",
            "random",
            "zero",
            "untrained"
          ]
        },
        "ordered_record_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/recordId"
          }
        }
      }
    },
    "signatureLayout": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "semantic_version",
        "bins",
        "layout",
        "n_neurons",
        "signature_width",
        "completion_steps",
        "dtype"
      ],
      "properties": {
        "semantic_version": {
          "const": "snn-temporal-signature-v2"
        },
        "bins": {
          "const": 8
        },
        "layout": {
          "const": "neuron-major"
        },
        "n_neurons": {
          "type": "integer",
          "minimum": 2
        },
        "signature_width": {
          "type": "integer",
          "minimum": 16
        },
        "completion_steps": {
          "type": "integer",
          "minimum": 32,
          "multipleOf": 8
        },
        "dtype": {
          "const": "<f8"
        }
      }
    },
    "signatures": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "file_sha256",
        "raw_bytes_sha256",
        "decoded_float64_digest",
        "shape",
        "byte_length",
        "row_digests"
      ],
      "properties": {
        "path": {
          "const": "signatures.bin"
        },
        "file_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "raw_bytes_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "decoded_float64_digest": {
          "$ref": "#/$defs/sha256"
        },
        "shape": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {
            "type": "integer",
            "minimum": 1
          }
        },
        "byte_length": {
          "type": "integer",
          "minimum": 1
        },
        "row_digests": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/sha256"
          }
        }
      }
    },
    "scoring": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scoring_target_self_sha256",
        "candidate_bank_digest",
        "abstention_rule",
        "calibration_spec_digest",
        "development_artifact_digest",
        "completion_steps"
      ],
      "properties": {
        "scoring_target_self_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "candidate_bank_digest": {
          "$ref": "#/$defs/sha256"
        },
        "abstention_rule": {
          "const": "strict_greater_than"
        },
        "calibration_spec_digest": {
          "$ref": "#/$defs/sha256"
        },
        "development_artifact_digest": {
          "$ref": "#/$defs/sha256"
        },
        "completion_steps": {
          "type": "integer",
          "minimum": 32,
          "multipleOf": 8
        }
      }
    },
    "build": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "encoder_directory_digest",
        "encoder_config_digest",
        "materializer_module_sha256",
        "backend_build_digest",
        "python_wheel_sha256",
        "rust_wheel_sha256",
        "repository_head",
        "patch_digest",
        "checkpoint_schema_sha256",
        "bank_schema_sha256"
      ],
      "properties": {
        "encoder_directory_digest": {
          "$ref": "#/$defs/sha256"
        },
        "encoder_config_digest": {
          "$ref": "#/$defs/sha256"
        },
        "materializer_module_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "backend_build_digest": {
          "$ref": "#/$defs/sha256"
        },
        "python_wheel_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "rust_wheel_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "repository_head": {
          "$ref": "#/$defs/gitSha1"
        },
        "patch_digest": {
          "$ref": "#/$defs/sha256"
        },
        "checkpoint_schema_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "bank_schema_sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    }
  }
}
